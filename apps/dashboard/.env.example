# API URL (local dev → http://localhost:3001 | prod → https://api.scrollpop.online)
VITE_API_URL=http://localhost:3001

# Clerk Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Publishable Key (for Stripe.js / Payment Element in checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# PostHog product analytics (loaded from CDN, no npm dep). Project API key from posthog.com.
VITE_POSTHOG_KEY=phc_xxx
# Optional — defaults to https://us.i.posthog.com. Use https://eu.i.posthog.com for an EU project.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry front-end error tracking (loaded from CDN, no npm dep).
# DSN from Sentry → Project → Settings → Client Keys (DSN).
VITE_SENTRY_DSN=

# NOTE: A real Clerk publishable key (pk_test_… is fine) is REQUIRED — there is no longer a
# keyless demo/showcase mode. Without VITE_CLERK_PUBLISHABLE_KEY the app cannot render.
