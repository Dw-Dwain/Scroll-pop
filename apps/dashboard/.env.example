# API URL (local dev → http://localhost:3001 | prod → https://api.scrollpop.io)
VITE_API_URL=http://localhost:3001

# Clerk Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Publishable Key (for Stripe.js / Payment Element in checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# PostHog product analytics
VITE_POSTHOG_KEY=phc_xxx

# Demo mode — bypasses Clerk hosted sign-in in local dev
# Set to false or remove in production
VITE_DEMO_MODE=true
