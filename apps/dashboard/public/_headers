# Cloudflare Pages security headers for the ScrollPop admin dashboard.
# Applied to every response. See https://developers.cloudflare.com/pages/configuration/headers/
#
# The enforced headers below are all non-breaking. The Content-Security-Policy ships in
# REPORT-ONLY mode first so it can never break the live app — review violation reports, then
# promote to the enforcing `Content-Security-Policy` header by renaming it once it's clean.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(self "https://js.stripe.com")
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://clerk.scrollpop.online https://challenges.cloudflare.com https://js.stripe.com https://*.posthog.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://scroll-pop.onrender.com https://clerk.scrollpop.online https://*.clerk.accounts.dev https://*.posthog.com https://api.stripe.com; frame-src https://js.stripe.com https://challenges.cloudflare.com https://*.clerk.accounts.dev; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
