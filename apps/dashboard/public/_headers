# Cloudflare Pages security headers for the ScrollPop admin dashboard.
# Applied to every response. See https://developers.cloudflare.com/pages/configuration/headers/
#
# The Content-Security-Policy below is ENFORCING (L-1). It was validated in report-only mode
# first. A report-only copy is kept alongside so any future violation still surfaces in reports
# without being silently dropped. If you add a new third-party origin, update BOTH lines.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(self "https://js.stripe.com")
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://clerk.scrollpop.online https://challenges.cloudflare.com https://js.stripe.com https://*.posthog.com https://js.sentry-cdn.com https://*.sentry-cdn.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://scrollpop-api.fly.dev https://clerk.scrollpop.online https://*.clerk.accounts.dev https://*.posthog.com https://api.stripe.com https://*.sentry.io https://cloudflareinsights.com; frame-src https://js.stripe.com https://challenges.cloudflare.com https://*.clerk.accounts.dev; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://clerk.scrollpop.online https://challenges.cloudflare.com https://js.stripe.com https://*.posthog.com https://js.sentry-cdn.com https://*.sentry-cdn.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://scrollpop-api.fly.dev https://clerk.scrollpop.online https://*.clerk.accounts.dev https://*.posthog.com https://api.stripe.com https://*.sentry.io https://cloudflareinsights.com; frame-src https://js.stripe.com https://challenges.cloudflare.com https://*.clerk.accounts.dev; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
