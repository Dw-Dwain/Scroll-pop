{
  "name": "@scrollpop/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "echo 'ESLint runs via root workspace — no local eslint in api'",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/fastify": "^2.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@scrollpop/shared": "workspace:*",
    "@upstash/redis": "^1.34.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-plugin": "^6.0.0",
    "postgres": "^3.4.0",
    "sanitize-html": "^2.17.5",
    "stripe": "^22.2.1",
    "svix": "^1.95.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/sanitize-html": "^2.13.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
