# Database (Neon / local Docker)
DATABASE_URL=postgresql://scrollpop:scrollpop_dev@localhost:5433/scrollpop
DIRECT_DATABASE_URL=postgresql://scrollpop:scrollpop_dev@localhost:5433/scrollpop

# Redis (Upstash in prod, local Redis for dev)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Stripe
# Create at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx   # from Stripe → Webhooks → your endpoint → Signing secret
# Price IDs: create recurring prices in Stripe → Products → Add product → set price → copy ID
STRIPE_PRICE_STARTER=price_xxx    # $19/mo — 25k views
STRIPE_PRICE_GROWTH=price_xxx     # $49/mo — 150k views
STRIPE_PRICE_SCALE=price_xxx      # $129/mo — 500k views
STRIPE_PRICE_AGENCY=price_xxx     # $299/mo — 2M views
# Stripe webhook endpoint to register: https://scrollpop-api.fly.dev/api/v1/webhooks/stripe
# Events to enable: customer.subscription.created, customer.subscription.updated,
#                   customer.subscription.deleted, checkout.session.completed

# Super-admin (only this email gets access to /admin panel)
ADMIN_EMAIL=dwain3991@gmail.com

# Cloudflare (for KV writes on campaign publish)
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_API_TOKEN=xxx
CLOUDFLARE_KV_NAMESPACE_ID=xxx

# Shopify App (create at https://partners.shopify.com)
SHOPIFY_API_KEY=shppa_xxx
SHOPIFY_API_SECRET=shpss_xxx
SHOPIFY_SCOPES=read_products,write_script_tags
# 32-byte key for encrypting secrets at rest (AES-256-GCM): Shopify OAuth tokens, ESP API keys
# (Klaviyo/Mailchimp), and outbound-webhook signing secrets. REQUIRED in production — the API
# refuses to boot-store secrets as plaintext without it (M-1/M-2/M-3).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SHOPIFY_ENCRYPTION_KEY=

# URLs (used in Shopify OAuth redirects)
API_BASE_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:5173

# Snippet CDN (baked into script tag URL injected into Shopify stores)
SNIPPET_CDN_URL=https://cdn.scrollpop.online

# App
PORT=3001
NODE_ENV=development
INTERNAL_SECRET=change_me_in_production_32_chars_min

# Database row-level-security enforcement (C-1). Active ONLY when DB_RLS_ENFORCED=true AND
# DB_TENANT_URL is set. When active, authenticated requests run on a dedicated NOBYPASSRLS role with
# a per-request app.current_tenant GUC, and tenant tables have FORCE RLS — so a query that forgets
# its tenant filter returns ZERO rows instead of leaking. The app's normal (superuser) role keeps
# bypassing RLS for system paths. Fail-safe: if setup fails the app logs and runs app-layer-only.
#
# One-time setup before enabling (see MASTER §RLS):
#   1. CREATE ROLE scrollpop_tenant LOGIN PASSWORD '<strong-pw>' NOBYPASSRLS;   -- on scrollpop-db
#   2. Set DB_TENANT_URL to that role's connection string — use a SESSION-MODE/direct connection
#      (NOT a pgbouncer transaction-pool port), so the per-request session GUC sticks.
#   3. Set DB_RLS_ENFORCED=true. Boot applies policies + grants idempotently (ensure-rls.ts).
# Validate auth, admin console, team invites, Shopify, leads, analytics in staging first.
DB_RLS_ENFORCED=false
DB_TENANT_URL=
# DB_TENANT_ROLE=scrollpop_tenant   # override only if you named the role differently

# Sentry (server error tracking) — create a Node project at https://sentry.io, copy its DSN.
# Dormant until set; no @sentry/node dependency (events POST to Sentry's ingest API via fetch).
SENTRY_DSN=

# Resend (transactional email for notifications) — https://resend.com
# RESEND_FROM must be on a domain you've verified in Resend (Domains → Add).
# Dormant until BOTH are set.
RESEND_API_KEY=
RESEND_FROM=ScrollPop <notifications@scrollpop.online>
