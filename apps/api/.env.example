# Database (Supabase / local Docker)
DATABASE_URL=postgresql://scrollpop:scrollpop_dev@localhost:5433/scrollpop
DIRECT_DATABASE_URL=postgresql://scrollpop:scrollpop_dev@localhost:5433/scrollpop

# Redis (Upstash in prod, local Redis for dev)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_AGENCY=price_xxx

# Cloudflare (for KV writes on campaign publish)
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_API_TOKEN=xxx
CLOUDFLARE_KV_NAMESPACE_ID=xxx

# Shopify App (create at https://partners.shopify.com)
SHOPIFY_API_KEY=shppa_xxx
SHOPIFY_API_SECRET=shpss_xxx
SHOPIFY_SCOPES=read_products,write_script_tags

# URLs (used in Shopify OAuth redirects)
API_BASE_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:5173

# Snippet CDN (baked into script tag URL injected into Shopify stores)
SNIPPET_CDN_URL=https://cdn.scrollpop.io

# App
PORT=3001
NODE_ENV=development
API_SECRET=change_me_in_production_32_chars_min
INTERNAL_SECRET=change_me_in_production_32_chars_min

# Sentry
SENTRY_DSN=
